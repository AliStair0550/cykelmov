# ----------------------------------------------------------
# Cykelmov v2 — miljovariabler
# Kopier denne fil til .env og udfyld vaerdierne.
# De samme vaerdier laegges ind i Cloudflare Pages > Settings > Environment variables.
# ----------------------------------------------------------

# Sanity-projektet. Findes i Sanity Manage (manage.sanity.io) under projektets ID.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# API-version til Sanity (dato). Aendres normalt ikke.
PUBLIC_SANITY_API_VERSION=2024-01-01

# Skrivetoken. KUN til reservationsformularen (opretter foresporgsel-dokumenter).
# Oprettes i Sanity Manage > API > Tokens med rollen "Editor". Del den aldrig offentligt.
SANITY_API_TOKEN=

# Web3Forms access key (samme noegle som det eksisterende site).
# Hentes paa https://web3forms.com
PUBLIC_WEB3FORMS_KEY=

# Sitens offentlige adresse. Bruges til canonical, Open Graph og sitemap.
PUBLIC_SITE_URL=https://cykelmov.dk
