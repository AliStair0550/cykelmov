# Sanity Studio — miljovariabler
# Kopier til sanity/.env

# Projektets ID (fra manage.sanity.io). Bruges af Studio, CLI og seed-script.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Underdomaene til `npm run deploy` -> <host>.sanity.studio
SANITY_STUDIO_HOST=cykelmov

# Skrivetoken (rollen "Editor"). KUN til seed-scriptet, ikke til Studio.
SANITY_API_TOKEN=
