---
import type { Billede } from '../lib/types';
export interface Props {
  billeder: Billede[];
}
const { billeder } = Astro.props;
const foerste = billeder[0];
---

<div class="galleri">
  <div class="galleri-stort">
    {foerste ? (
      <img id="galleri-hoved" src={foerste.url} alt={foerste.alt} width="1200" height="900" role="button" tabindex="0" aria-label="Åbn billedet i stor visning" />
    ) : (
      <img id="galleri-hoved" src="/assets/butik-hjul.jpg" alt="Cykel" width="1200" height="900" />
    )}
  </div>
  {billeder.length > 1 && (
    <div class="galleri-thumbs">
      {billeder.map((b, i) => (
        <button
          class={`galleri-thumb${i === 0 ? ' aktiv' : ''}`}
          type="button"
          data-src={b.url}
          data-alt={b.alt}
          aria-label={`Vis billede ${i + 1}`}
        >
          <img src={b.thumbUrl} alt="" loading="lazy" />
        </button>
      ))}
    </div>
  )}
</div>

<!-- Lightbox: åbner billedet i stor visning ved tryk -->
<div class="lightbox" id="lightbox" hidden aria-hidden="true">
  <button class="lightbox-luk" type="button" aria-label="Luk stor visning">×</button>
  <img id="lightbox-img" src="" alt="" />
</div>

<script>
  const hoved = document.getElementById('galleri-hoved') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.galleri-thumb');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

  thumbs.forEach((t) => {
    t.addEventListener('click', () => {
      if (hoved) {
        hoved.src = t.dataset.src || hoved.src;
        hoved.alt = t.dataset.alt || '';
      }
      thumbs.forEach((x) => x.classList.remove('aktiv'));
      t.classList.add('aktiv');
    });
  });

  function aabnLightbox() {
    if (!lb || !lbImg || !hoved) return;
    lbImg.src = hoved.src;
    lbImg.alt = hoved.alt;
    lb.hidden = false;
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function lukLightbox() {
    if (!lb) return;
    lb.hidden = true;
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hoved?.addEventListener('click', aabnLightbox);
  hoved?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      aabnLightbox();
    }
  });
  lb?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t === lb || t.closest('.lightbox-luk')) lukLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lb && !lb.hidden) lukLightbox();
  });
</script>
