---
import { site } from '../lib/site';
const aar = 2026;
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <a href="/" class="logo" style="color:#fff;margin-bottom:14px">
        <svg class="hjul" style="color:var(--signal)" viewBox="0 0 34 22" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg"><g stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M8 16 16 16 12 7 21 7 16 16M12 7 8 16M21 7 26 16"/><path d="M12 7V4.4"/><path d="M10.5 4.2H13.6" stroke-width="1.8"/><path d="M21 7V4.4M18.6 4.4H23.2" stroke-width="1.4"/><g class="hjul-spin"><circle cx="8" cy="16" r="5"/><path d="M8 11.2v9.6M3.2 16h9.6M4.6 12.6l6.8 6.8M11.4 12.6l-6.8 6.8" stroke-width="1"/></g><g class="hjul-spin"><circle cx="26" cy="16" r="5"/><path d="M26 11.2v9.6M21.2 16h9.6M22.6 12.6l6.8 6.8M29.4 12.6l-6.8 6.8" stroke-width="1"/></g></g></svg>Cykel<em style="color:var(--signal)">mov</em>
      </a>
      <p style="color:rgba(245,243,237,.6);font-size:.92rem;max-width:32ch">
        {site.tagline}. Nye og brugte cykler, eget værksted og priser uden overraskelser.
      </p>
    </div>
    <div>
      <h4>Cykler</h4>
      <a href="/cykler/dame/">Damecykler</a>
      <a href="/cykler/herre/">Herrecykler</a>
      <a href="/cykler/boern/">Børnecykler</a>
      <a href="/cykler/">Alle cykler</a>
    </div>
    <div>
      <h4>Værksted</h4>
      <a href="/vaerksted/">Priser & booking</a>
      <a href="/vaerksted/#faq">Ofte stillede spørgsmål</a>
      <a href="/vaerksted/">Elcykel-service</a>
    </div>
    <div>
      <h4>Butik</h4>
      <a href="/om/">Om Cykelmov</a>
      <a href="/kontakt/">Kontakt</a>
      <a href={`tel:${site.telefonE164}`}>{site.telefon}</a>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={site.maps}>{site.adresse.gade.replace(', st. tv.', '')}, {site.adresse.postnr} {site.adresse.by}</a>
    </div>
  </div>
  <div class="wrap footer-bund">
    <span>© 2021-{aar} Cykelmov · Alle rettigheder forbeholdes</span>
    <span>Handelsbetingelser · Privatlivspolitik</span>
  </div>
</footer>
