---
import { tidValg } from '../lib/site';
import { hentTilkoeb } from '../lib/data';
import { kr } from '../lib/format';
// Fælles reservations-/booking-modal. Ét eksemplar pr. side (via Layout).
// Åbnes af knapper med [data-reserver] (se ReserverKnap.astro).
const tilkoeb = await hentTilkoeb();

// Emoji-fallback til tilkøb uden uploadet billede (fx demo-data).
function tilkoebIkon(navn: string): string {
  const n = navn.toLowerCase();
  if (/lås|laas|lock/.test(n)) return '🔒';
  if (/lygte|lys|light/.test(n)) return '💡';
  if (/bagage|kurv|rack/.test(n)) return '🧺';
  if (/kæde|kaede|chain/.test(n)) return '⛓️';
  if (/klokke|ringe|bell/.test(n)) return '🔔';
  if (/hjelm|helmet/.test(n)) return '⛑️';
  if (/pumpe|pump|lap/.test(n)) return '🩹';
  return '🚲';
}
---

<div class="modal-bag" id="reserver-bag" role="dialog" aria-modal="true" aria-labelledby="reserver-titel" aria-hidden="true">
  <div class="modal" tabindex="-1">
    <div class="modal-hoved">
      <h3 id="reserver-titel">Reservér & afhent</h3>
      <button class="luk" type="button" aria-label="Luk">×</button>
    </div>
    <div class="modal-krop">
      <div class="valgt-cykel" id="reserver-objekt" hidden>
        <img id="reserver-objekt-foto" src="" alt="" width="84" height="84" hidden />
        <span class="objekt-ikon" id="reserver-objekt-ikon" hidden aria-hidden="true"></span>
        <div>
          <b id="reserver-objekt-navn"></b>
          <div class="p" id="reserver-objekt-pris" hidden></div>
        </div>
      </div>

      <p class="reserver-note" id="reserver-note"></p>

      <form id="reserver-form" action="/api/reserver" method="POST">
        <input type="hidden" name="type" id="rf-type" value="cykel" />
        <input type="hidden" name="objekt" id="rf-objekt" value="" />
        <input type="hidden" name="reference" id="rf-reference" value="" />
        <input type="hidden" name="pris" id="rf-pris" value="0" />
        <!-- Honeypot mod spam (Web3Forms botcheck) -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none !important" tabindex="-1" autocomplete="off" aria-hidden="true" />

        {tilkoeb.length > 0 && (
          <div class="tilkoeb-sektion" id="tilkoeb-sektion" hidden>
            <h4 class="tilkoeb-titel">Tilføj tilbehør <span>valgfrit</span></h4>
            <div class="tilkoeb-liste">
              {tilkoeb.map((t) => (
                <label class="tilkoeb-val">
                  <input type="checkbox" name="tilkoeb" value={`${t.navn} (+${t.pris} kr.)`} data-pris={t.pris} />
                  <span class="tilkoeb-medie">
                    {t.billede ? (
                      <img src={t.billede.thumbUrl} alt={t.billede.alt} width="52" height="52" loading="lazy" />
                    ) : (
                      <span class="tilkoeb-emoji" aria-hidden="true">{tilkoebIkon(t.navn)}</span>
                    )}
                  </span>
                  <span class="tilkoeb-info">
                    <b>{t.navn}</b>
                    {t.beskrivelse && <small>{t.beskrivelse}</small>}
                  </span>
                  <span class="tilkoeb-pris">+{kr(t.pris)}</span>
                  <span class="tilkoeb-tjek" aria-hidden="true">✓</span>
                </label>
              ))}
            </div>
            <p class="tilkoeb-total" id="tilkoeb-total"></p>
          </div>
        )}

        <div class="felt">
          <label for="rf-navn">Navn</label>
          <input id="rf-navn" name="navn" type="text" required autocomplete="name" placeholder="Dit fulde navn" />
        </div>
        <div class="felt">
          <label for="rf-tlf">Mobilnummer</label>
          <input id="rf-tlf" name="telefon" type="tel" required autocomplete="tel" placeholder="Så vi kan bekræfte din bestilling" />
        </div>
        <div class="felt">
          <label for="rf-email">E-mail</label>
          <input id="rf-email" name="email" type="email" required autocomplete="email" placeholder="dig@eksempel.dk" />
        </div>
        <div class="felt">
          <label for="rf-tid" id="rf-tid-label">Hvornår vil du hente?</label>
          <select id="rf-tid" name="tid">
            {tidValg.map((t) => <option value={t.value}>{t.label}</option>)}
          </select>
        </div>
        <div class="felt">
          <label for="rf-besked">Besked (valgfri)</label>
          <textarea id="rf-besked" name="besked" rows="3" placeholder="Størrelse, farve eller spørgsmål ..."></textarea>
        </div>

        <button type="submit" class="btn btn-cobalt" id="rf-submit">
          Send reservation <span class="pil">→</span>
        </button>
        <p style="font-size:.8rem;color:var(--grå);text-align:center;margin-top:12px">
          Ingen betaling nu. Du henter selv i butikken og betaler først, når du står med varen.
        </p>
      </form>
    </div>
  </div>
</div>

<script>
  const bag = document.getElementById('reserver-bag');
  if (bag) {
    const titel = document.getElementById('reserver-titel');
    const objektBoks = document.getElementById('reserver-objekt');
    const objektFoto = document.getElementById('reserver-objekt-foto') as HTMLImageElement | null;
    const objektIkon = document.getElementById('reserver-objekt-ikon');
    const objektNavn = document.getElementById('reserver-objekt-navn');
    const objektPris = document.getElementById('reserver-objekt-pris');
    const fType = document.getElementById('rf-type') as HTMLInputElement | null;
    const fObjekt = document.getElementById('rf-objekt') as HTMLInputElement | null;
    const fRef = document.getElementById('rf-reference') as HTMLInputElement | null;
    const submitKnap = document.getElementById('rf-submit');
    const note = document.getElementById('reserver-note');
    const tidLabel = document.getElementById('rf-tid-label');
    const modalEl = bag.querySelector('.modal') as HTMLElement | null;
    const tilkoebSektion = document.getElementById('tilkoeb-sektion');
    const tilkoebTotal = document.getElementById('tilkoeb-total');
    const tilkoebInputs = Array.from(
      bag.querySelectorAll<HTMLInputElement>('input[name="tilkoeb"]'),
    );
    let cykelPris = 0;
    let sidsteFokus: HTMLElement | null = null;

    const krFmt = (n: number) => n.toLocaleString('da-DK') + ' kr.';
    function opdaterTotal() {
      if (!tilkoebTotal) return;
      const valgt = tilkoebInputs.filter((i) => i.checked);
      const sum = valgt.reduce((s, i) => s + Number(i.dataset.pris || 0), 0);
      if (valgt.length === 0) {
        tilkoebTotal.innerHTML =
          '<span class="muted">Tilkøb lægges oven i cyklens pris — du betaler i butikken.</span>';
      } else {
        tilkoebTotal.innerHTML = `<b>I alt ca. ${krFmt(cykelPris + sum)}</b> · cykel + ${valgt.length} tilkøb (${krFmt(sum)})`;
      }
    }
    tilkoebInputs.forEach((i) =>
      i.addEventListener('change', () => {
        i.closest('.tilkoeb-val')?.classList.toggle('valgt', i.checked);
        opdaterTotal();
      }),
    );

    function fokusbare(): HTMLElement[] {
      if (!modalEl) return [];
      return Array.from(
        modalEl.querySelectorAll<HTMLElement>(
          'a[href],button:not([disabled]),input:not([disabled]),select,textarea',
        ),
      ).filter((el) => el.offsetParent !== null);
    }

    function aaben() {
      bag!.classList.add('aaben');
      bag!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Start altid HELT øverst, så man ser cyklen + "Tilføj tilbehør" først.
      // Vi fokuserer selve dialogen (ikke et tekstfelt) — så popper mobil-
      // tastaturet ikke op og scroller ned til navn-feltet.
      if (modalEl) modalEl.scrollTop = 0;
      window.setTimeout(() => {
        if (modalEl) {
          modalEl.scrollTop = 0;
          modalEl.focus({ preventScroll: true });
        }
      }, 40);
    }
    function luk() {
      bag!.classList.remove('aaben');
      bag!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (sidsteFokus && typeof sidsteFokus.focus === 'function') sidsteFokus.focus();
    }

    // Åbn fra en hvilken som helst [data-reserver]-knap.
    document.addEventListener('click', (ev) => {
      const knap = (ev.target as HTMLElement)?.closest('[data-reserver]') as HTMLElement | null;
      if (knap) {
        ev.preventDefault();
        sidsteFokus = knap;
        const type = knap.dataset.reserver || 'cykel';
        const navn = knap.dataset.navn || '';
        const ref = knap.dataset.ref || '';
        const pris = knap.dataset.pris || '';
        const img = knap.dataset.img || '';
        const ikon = knap.dataset.ikon || '';

        if (fType) fType.value = type;
        if (fObjekt) fObjekt.value = navn;
        if (fRef) fRef.value = ref;
        if (titel) titel.textContent = type === 'ydelse' ? 'Book værkstedstid' : 'Reservér til afhentning';
        if (submitKnap) submitKnap.firstChild!.textContent = type === 'ydelse' ? 'Send booking ' : 'Send reservation ';
        if (type === 'ydelse') {
          if (note)
            note.textContent =
              'Kom forbi med cyklen på Nørrebrogade 74. Du betaler først, når arbejdet er lavet.';
          if (tidLabel) tidLabel.textContent = 'Hvornår kommer du forbi?';
        } else {
          if (note) note.textContent = '';
          if (tidLabel) tidLabel.textContent = 'Hvornår vil du hente den?';
        }

        // Tilkøb: kun ved cykel-reservation. Nulstil valg ved hver åbning.
        cykelPris = parseInt((pris || '').replace(/\D/g, ''), 10) || 0;
        // Pris med i formularen, så GA4-eventet kan sende value (tal) + DKK.
        const prisFelt = document.getElementById('rf-pris') as HTMLInputElement | null;
        if (prisFelt) prisFelt.value = String(cykelPris);
        tilkoebInputs.forEach((i) => {
          i.checked = false;
          i.closest('.tilkoeb-val')?.classList.remove('valgt');
        });
        if (tilkoebSektion) {
          if (type === 'cykel' && tilkoebInputs.length) {
            tilkoebSektion.hidden = false;
            opdaterTotal();
          } else {
            tilkoebSektion.hidden = true;
          }
        }

        if (navn && objektNavn && objektBoks) {
          objektNavn.textContent = navn;
          objektBoks.hidden = false;
          if (objektFoto && objektIkon) {
            if (img) {
              objektFoto.src = img;
              objektFoto.alt = navn;
              objektFoto.hidden = false;
              objektIkon.hidden = true;
            } else if (ikon) {
              objektIkon.textContent = ikon;
              objektIkon.hidden = false;
              objektFoto.hidden = true;
            } else {
              objektFoto.hidden = true;
              objektIkon.hidden = true;
            }
          }
          if (objektPris) {
            if (pris) {
              objektPris.textContent = pris;
              objektPris.hidden = false;
            } else {
              objektPris.hidden = true;
            }
          }
        } else if (objektBoks) {
          objektBoks.hidden = true;
        }
        aaben();
        return;
      }
      // Luk
      const target = ev.target as HTMLElement;
      if (target === bag || target.closest('.luk')) luk();
    });

    document.addEventListener('keydown', (e) => {
      if (!bag!.classList.contains('aaben')) return;
      if (e.key === 'Escape') {
        luk();
        return;
      }
      // Fokusfælde: hold Tab inde i modalen
      if (e.key === 'Tab') {
        const f = fokusbare();
        if (!f.length) return;
        const foerste = f[0];
        const sidste = f[f.length - 1];
        if (e.shiftKey && document.activeElement === foerste) {
          e.preventDefault();
          sidste.focus();
        } else if (!e.shiftKey && document.activeElement === sidste) {
          e.preventDefault();
          foerste.focus();
        }
      }
    });
  }
</script>
