---
// Injicerer et JSON-LD schema-objekt i head. Brug via <slot name="head">.
export interface Props {
  data: Record<string, unknown> | Record<string, unknown>[];
}
const { data } = Astro.props;
// Escapér < > & så indhold (fx en produkttitel med "</script>") ikke kan
// bryde ud af JSON-LD-blokken.
const json = JSON.stringify(data)
  .replace(/</g, '\\u003c')
  .replace(/>/g, '\\u003e')
  .replace(/&/g, '\\u0026');
---
<script type="application/ld+json" set:html={json} is:inline />
