---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReserverModal from '../components/ReserverModal.astro';
import { site } from '../lib/site';

export interface Props {
  /** Sidespecifik titel. Sammensættes til "{title} | Cykelmov, gadens cykelbutik". */
  title: string;
  /** Overstyr hele title-taggen (fx forsiden). */
  titelFuld?: string;
  description: string;
  /** Absolut eller rod-relativ sti til delebillede (Open Graph). */
  ogBillede?: string;
  /** Body-klasser, fx "dame-side univers-dame". */
  bodyKlasse?: string;
  /** Mørk header (til sider med mørk hero, fx herre/værksted). */
  headerMoerk?: boolean;
  /** Vis reservations-modal på siden (default true). */
  medModal?: boolean;
}

const {
  title,
  titelFuld,
  description,
  ogBillede = '/assets/hero-butik.jpg',
  bodyKlasse = '',
  headerMoerk = false,
  medModal = true,
} = Astro.props;

const fuldTitel = titelFuld ?? `${title} | ${site.slogan}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogAbsolut = new URL(ogBillede, Astro.site ?? site.url).href;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NYT1TE3QL0" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NYT1TE3QL0');
    </script>

    <title>{fuldTitel}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#1D3EE3" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cykelmov" />
    <meta property="og:title" content={fuldTitel} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogAbsolut} />
    <meta property="og:locale" content="da_DK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fuldTitel} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbsolut} />

    <!-- Billeder fra Sanitys CDN — varm forbindelsen tidligt -->
    <link rel="preconnect" href="https://cdn.sanity.io" />

    <!-- Skrifttyper -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Schibsted+Grotesk:wght@400;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class={bodyKlasse}>
    <Header moerk={headerMoerk} />
    <slot />
    <Footer />
    {medModal && <ReserverModal />}

    <script>
      // gtag defineres globalt af GA4-snippettet i <head>.
      declare function gtag(...args: unknown[]): void;

      // Burger-menu
      const burger = document.querySelector('.burger');
      const navLinks = document.querySelector('.nav-links');
      burger?.addEventListener('click', () => {
        const aaben = navLinks?.classList.toggle('aaben');
        burger.setAttribute('aria-expanded', aaben ? 'true' : 'false');
      });
      // Luk mobilmenu når der klikkes på et link
      navLinks?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
          navLinks.classList.remove('aaben');
          burger?.setAttribute('aria-expanded', 'false');
        }),
      );

      // Formular: loading-state, ingen dobbeltindsendelse, offline-fallback med telefon
      document.querySelectorAll('form[action="/api/reserver"]').forEach((form) => {
        const f = form as HTMLFormElement;
        f.addEventListener('submit', async (e) => {
          if (f.dataset.sender === '1') {
            e.preventDefault();
            return;
          }
          e.preventDefault();
          if (!f.checkValidity()) {
            f.reportValidity();
            return;
          }
          const btn = f.querySelector('[type="submit"]') as HTMLButtonElement | null;
          const btnHtml = btn ? btn.innerHTML : '';
          f.dataset.sender = '1';
          if (btn) {
            btn.disabled = true;
            btn.textContent = 'Sender …';
          }
          try {
            const res = await fetch(f.action, {
              method: 'POST',
              body: new FormData(f),
              headers: { Accept: 'text/html' },
            });
            if (res.ok || res.redirected) {
              // GA4-event ved gennemført booking (kører uanset om Web3Forms lykkedes)
              const bookingType =
                (f.querySelector('[name="type"]') as HTMLInputElement | null)?.value || 'cykel';
              const pris = Number(
                (f.querySelector('[name="pris"]') as HTMLInputElement | null)?.value || 0,
              );
              if (typeof gtag === 'function') {
                if (bookingType === 'ydelse')
                  gtag('event', 'booking_vaerksted', { value: pris, currency: 'DKK' });
                else if (bookingType === 'cykel')
                  gtag('event', 'reservation_cykel', { value: pris, currency: 'DKK' });
              }
              window.location.href = '/reserver/?tak=1';
              return;
            }
            throw new Error('status ' + res.status);
          } catch (err) {
            f.dataset.sender = '';
            if (btn) {
              btn.disabled = false;
              btn.innerHTML = btnHtml;
            }
            let fejl = f.querySelector('.form-fejl') as HTMLElement | null;
            if (!fejl) {
              fejl = document.createElement('p');
              fejl.className = 'form-fejl';
              f.appendChild(fejl);
            }
            fejl.innerHTML =
              'Noget gik galt med at sende. Ring til os på <a href="tel:+4531327055">31 32 70 55</a>, så hjælper vi dig.';
          }
        });
      });

      // Scroll-reveal
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('synlig');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // GA4: klik på telefon-links (klik_ring)
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement)?.closest('a');
        if (!a) return;
        if ((a.getAttribute('href') || '').startsWith('tel:') && typeof gtag === 'function') {
          gtag('event', 'klik_ring');
        }
      });
    </script>
  </body>
</html>
