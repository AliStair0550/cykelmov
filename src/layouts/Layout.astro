---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReserverModal from '../components/ReserverModal.astro';
import { site } from '../lib/site';

export interface Props {
  /** Sidespecifik titel. Sammensættes til "{title} | Cykelmov, gadens cykelbutik". */
  title: string;
  /** Overstyr hele title-taggen (fx forsiden). */
  titelFuld?: string;
  description: string;
  /** Absolut eller rod-relativ sti til delebillede (Open Graph). */
  ogBillede?: string;
  /** Body-klasser, fx "dame-side univers-dame". */
  bodyKlasse?: string;
  /** Mørk header (til sider med mørk hero, fx herre/værksted). */
  headerMoerk?: boolean;
  /** Vis reservations-modal på siden (default true). */
  medModal?: boolean;
}

const {
  title,
  titelFuld,
  description,
  ogBillede = '/assets/hero-butik.jpg',
  bodyKlasse = '',
  headerMoerk = false,
  medModal = true,
} = Astro.props;

const fuldTitel = titelFuld ?? `${title} | ${site.slogan}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogAbsolut = new URL(ogBillede, Astro.site ?? site.url).href;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fuldTitel}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#1D3EE3" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cykelmov" />
    <meta property="og:title" content={fuldTitel} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogAbsolut} />
    <meta property="og:locale" content="da_DK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fuldTitel} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbsolut} />

    <!-- Skrifttyper -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Schibsted+Grotesk:wght@400;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class={bodyKlasse}>
    <Header moerk={headerMoerk} />
    <slot />
    <Footer />
    {medModal && <ReserverModal />}

    <script>
      // Burger-menu
      const burger = document.querySelector('.burger');
      const navLinks = document.querySelector('.nav-links');
      burger?.addEventListener('click', () => navLinks?.classList.toggle('aaben'));

      // Scroll-reveal
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('synlig');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
