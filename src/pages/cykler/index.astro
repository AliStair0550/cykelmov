---
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import KatalogSektion from '../../components/KatalogSektion.astro';
import StructuredData from '../../components/StructuredData.astro';
import { hentCykler } from '../../lib/data';
import { itemListSchema } from '../../lib/schema';

const cykler = await hentCykler();
const schema = itemListSchema(cykler, 'Cykler hos Cykelmov');
---

<Layout
  title="Bestil cykler online i København"
  description="Bestil din cykel online hos Cykelmov på Nørrebro. Bycykler, mountainbikes, elcykler og mere til dame, herre og børn. Filtrér på type, brand og pris, bestil online og afhent i dag."
>
  <StructuredData slot="head" data={schema} />

  <section
    class="side-hero"
    style="padding:150px 0 100px;background-image:linear-gradient(rgba(20,20,25,.5),rgba(20,20,25,.72)),url('/assets/cykler.jpg');background-size:cover;background-position:center 82%"
  >
    <div class="wrap">
      <span class="eyebrow ingen-streg">Butikken</span>
      <h1 class="display-xl" style="margin-top:14px">Alle cykler</h1>
      <p class="lead">
        Hele lageret ét sted. Filtrér på type, brand og pris, og find den, der passer til dig og
        din vej gennem byen.
      </p>
    </div>
  </section>

  <Ticker
    items={[
      'Reservér online, afhent i dag',
      '2 års garanti',
      'Gratis serviceaftale ved køb',
      'Samlet & køreklar fra butikken',
    ]}
  />

  <section>
    <KatalogSektion cykler={cykler} />
  </section>
</Layout>
