---
import Layout from '../layouts/Layout.astro';
import CykelbaneHero from '../components/CykelbaneHero.astro';
import Ticker from '../components/Ticker.astro';
import CykelKort from '../components/CykelKort.astro';
import YdelseKort from '../components/YdelseKort.astro';
import StructuredData from '../components/StructuredData.astro';
import { hentFremhaevede, hentYdelser } from '../lib/data';
import { site } from '../lib/site';

const fremhaevede = await hentFremhaevede(3);
const ydelser = (await hentYdelser()).slice(0, 3);

// LocalBusiness / BicycleStore schema
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'BicycleStore',
  name: site.navn,
  image: new URL('/assets/hero-butik.jpg', site.url).href,
  url: site.url + '/',
  telephone: site.telefonE164,
  email: site.email,
  priceRange: 'kr',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.adresse.gade,
    postalCode: site.adresse.postnr,
    addressLocality: site.adresse.by,
    addressCountry: site.adresse.land,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.adresse.lat, longitude: site.adresse.lng },
  openingHoursSpecification: site.aabningJsonLd.map((o) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: o.dage,
    opens: o.opens,
    closes: o.closes,
  })),
  sameAs: [],
};
---

<Layout
  title="Cykelbutik & værksted på Nørrebro"
  titelFuld="Cykelmov | Cykelbutik & cykelværksted på Nørrebro, København N"
  description="Nørrebros cykelbutik. Cykler til dame, herre og børn, eget værksted med faste priser og samme dags-service. Reservér online, afhent på Nørrebrogade 74."
>
  <StructuredData slot="head" data={localBusiness} />

  <CykelbaneHero
    bgBillede="/assets/hero-butik.jpg"
    foer="Nørrebro"
    midt="kører på"
    fremhaev="Cykelmov"
    lead="Københavner-cykler samlet, smurt og klar til brostenene. Reservér online, hent i butikken i dag, og betal først, når du får cyklen."
    badge="Op til<br>-25%<br>lige nu"
  >
    <a href="/cykler/dame" class="btn btn-signal">Damecykler <span class="pil">→</span></a>
    <a href="/cykler/herre" class="btn btn-lys">Herrecykler <span class="pil">→</span></a>
    <a href="/vaerksted" class="btn btn-ghost" style="color:#fff">Værksted</a>
  </CykelbaneHero>

  <Ticker
    items={[
      'Op til -25% på bycykler',
      'Gratis serviceaftale ved køb',
      'Reservér online, afhent i dag',
      '2 års garanti',
      'Lapning fra 99 kr.',
      'Nørrebrogade 74, 2200 KBH N',
    ]}
  />

  <!-- PORTALER -->
  <section>
    <div class="wrap">
      <div class="sektion-hoved reveal">
        <div><h2 class="display-l">Tre veje ind</h2></div>
        <p class="lead" style="max-width:38ch">
          Cykel til hende, cykel til ham, cykel til de mindste, eller nyt liv til den, du allerede
          elsker.
        </p>
      </div>
      <div class="portaler">
        <a href="/cykler/dame" class="portal portal-dame reveal">
          <span class="tag">Dame</span>
          <div class="bg" style="background-image:url('/assets/produkter/dame-merla.jpg')"></div>
          <h3>Damecykler</h3>
          <p>Klassikere med kurv, lav indstigning og oprejst holdning. Byen er din.</p>
          <span class="pris-fra">Fra 3.799 kr.</span>
        </a>
        <a href="/cykler/herre" class="portal portal-herre reveal">
          <span class="tag">Herre</span>
          <div class="bg" style="background-image:url('/assets/produkter/herre-movi.jpg')"></div>
          <h3>Herrecykler</h3>
          <p>Stålstel, Shimano-gear og plads til frontlad. Bygget til brosten og modvind.</p>
          <span class="pris-fra">Fra 4.999 kr.</span>
        </a>
        <a href="/vaerksted" class="portal portal-vaerksted reveal">
          <span class="tag">Værksted</span>
          <div class="bg" style="background-image:url('/assets/vaerksted-vaerktoej.jpg')"></div>
          <h3>Cykelværksted</h3>
          <p>Faste priser, ingen overraskelser. Lapning mens du venter, book din tid online.</p>
          <span class="pris-fra">Lapning fra 99 kr.</span>
        </a>
      </div>
    </div>
  </section>

  <!-- NYE I BUTIKKEN -->
  <section style="background:var(--kridt-2)">
    <div class="wrap">
      <div class="sektion-hoved reveal">
        <div>
          <span class="eyebrow">Nyheder</span>
          <h2 class="display-l">Nye i butikken</h2>
        </div>
        <a href="/cykler" class="btn btn-cobalt">Se alle cykler <span class="pil">→</span></a>
      </div>
      <div class="produkt-grid">
        {fremhaevede.map((c) => <CykelKort cykel={c} />)}
      </div>
    </div>
  </section>

  <!-- VÆRKSTED -->
  <section>
    <div class="wrap">
      <div class="sektion-hoved reveal">
        <div>
          <span class="eyebrow">Værksted</span>
          <h2 class="display-l">Fast pris, færdig i dag</h2>
        </div>
        <a href="/vaerksted" class="btn btn-ghost">Hele prislisten <span class="pil">→</span></a>
      </div>
      <div class="ydelse-grid">
        {ydelser.map((y) => <YdelseKort ydelse={y} />)}
      </div>
    </div>
  </section>

  <!-- USP -->
  <section class="usp-baand">
    <div class="wrap">
      <div class="usp-grid">
        <div class="usp reveal"><div class="tal">2 år</div><h3>Garanti på cyklen</h3><p>Og op til 15 års garanti på stellet. Vi står bag det, vi sælger.</p></div>
        <div class="usp reveal"><div class="tal">0 kr.</div><h3>Serviceaftale med i købet</h3><p>Gratis eftersyn efter 1-2 måneder plus løbende justering af gear, kæde og kabler.</p></div>
        <div class="usp reveal"><div class="tal">I dag</div><h3>Reservér & afhent</h3><p>Vælg cyklen online, hent den samlet og køreklar samme dag på Nørrebrogade.</p></div>
        <div class="usp reveal"><div class="tal">100%</div><h3>Samlet & klar</h3><p>Alle cykler leveres færdigmonterede, smurte og testet af vores mekanikere.</p></div>
      </div>
    </div>
  </section>

  <!-- TRYGHED -->
  <section class="tryghed">
    <div class="wrap tryghed-grid">
      <div class="reveal">
        <h2 class="display-l" style="margin-bottom:20px">Bedste kvalitet.<br>Skarpeste pris.</h2>
        <p class="lead" style="margin-bottom:26px">
          Vi importerer selv vores cykler og springer mellemleddene over. Derfor kan vi sælge
          kvalitetscykler til priser, der giver mening for studerende og alle andre københavnere.
        </p>
        <ul class="tjek-liste">
          <li><span class="tjek">✓</span><span><b>Gennemsigtige priser</b> Prisen på skiltet er prisen, du betaler. Altid.</span></li>
          <li><span class="tjek">✓</span><span><b>Gratis eftersyn efter 1-2 måneder</b> Vi strammer, justerer og smører, uden beregning.</span></li>
          <li><span class="tjek">✓</span><span><b>Samme komponenter som de store mærker</b> Shimano-gear, rustfri kæder og Kevlar-dæk med refleks.</span></li>
          <li><span class="tjek">✓</span><span><b>Indbyt din gamle cykel</b> Få den vurderet og træk beløbet fra din nye.</span></li>
        </ul>
      </div>
      <div class="tryghed-foto reveal">
        <img src="/assets/butik-cykelvaeg.jpg" alt="Cykler på væggen i Cykelmovs butik på Nørrebrogade" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ANMELDELSER -->
  <section style="background:var(--kridt-2)">
    <div class="wrap">
      <div class="sektion-hoved reveal"><div><h2 class="display-l">Naboer på hjul</h2></div></div>
      <div class="citater">
        <blockquote class="citat reveal"><div class="stjerner">★★★★★</div><p>Punkterede på vej til arbejde, trillede ind kl. 10, kørte videre 20 minutter senere. Det er service.</p><footer>Jonas · Stefansgade</footer></blockquote>
        <blockquote class="citat reveal"><div class="stjerner">★★★★★</div><p>Fik min damecykel med kurv til under 2.700 og gratis eftersyn ovenpå. Bedste handel i lang tid.</p><footer>Amina · Mimersgade</footer></blockquote>
        <blockquote class="citat reveal"><div class="stjerner">★★★★★</div><p>Ærlige folk. De sagde direkte, at min gamle cykel ikke var værd at reparere, og fandt en brugt til mig i stedet.</p><footer>Frederik · Jægersborggade</footer></blockquote>
      </div>
    </div>
  </section>

  <!-- BESØG -->
  <section class="besoeg">
    <div class="wrap besoeg-grid">
      <div class="reveal">
        <h2 class="display-l" style="margin:14px 0 26px">Midt på<br>Nørrebrogade</h2>
        <div class="info-linje"><b>Adresse</b><span>{site.adresse.gade} · {site.adresse.postnr} {site.adresse.by}</span></div>
        <div class="info-linje"><b>Telefon</b><span><a href={`tel:${site.telefonE164}`} style="text-decoration:underline">{site.telefon}</a></span></div>
        {site.aabningstider.map((a) => (
          <div class="info-linje"><b>{a.dage}</b><span>{a.tid}</span></div>
        ))}
        <a href={site.maps} class="btn btn-signal" style="margin-top:28px">Find vej <span class="pil">→</span></a>
      </div>
      <div class="besoeg-foto reveal">
        <img src="/assets/IMG_4312.jpeg" alt="Cykelmovs facade på Nørrebrogade 74 med cykler på gaden" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- SEO TEKST -->
  <section class="seo-tekst">
    <div class="wrap">
      <h2>Cykelbutik og cykelværksted på Nørrebro</h2>
      <p>
        Cykelmov er din lokale cykelhandler på Nørrebrogade 74 i 2200 København N. Vi sælger nye og
        brugte cykler til dame, herre og børn, herunder bycykler, mountainbikes og elcykler, og
        driver et professionelt cykelværksted med reparation af alle cykelmærker.
      </p>
      <p>
        Leder du efter en billig kvalitetscykel i København, kan du reservere den online og afhente
        samme dag i butikken. Har din cykel brug for lapning, slangeskift, gearjustering eller et
        serviceeftersyn, booker du en tid på få sekunder og betaler en fast, gennemsigtig pris.
      </p>
    </div>
  </section>
</Layout>
