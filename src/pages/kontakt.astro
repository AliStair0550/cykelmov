---
import Layout from '../layouts/Layout.astro';
import { site, tidValg } from '../lib/site';
---

<Layout
  title="Kontakt"
  description="Kontakt Cykelmov på Nørrebrogade 74, 2200 København N. Ring på 31 72 78 88, skriv til os, eller kig forbi. Se åbningstider og find vej."
>
  <section class="side-hero">
    <div class="wrap">
      <span class="eyebrow">Kontakt</span>
      <h1 class="display-xl" style="margin-top:14px">Skriv eller<br>kig forbi</h1>
      <p class="lead">
        Spørgsmål om en cykel, en reparation eller noget helt tredje? Vi svarer inden for én
        arbejdsdag.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="indhold-grid">
        <div class="reveal">
          <div class="kontakt-kort">
            <h2 class="display-m" style="margin-bottom:16px">Butikken</h2>
            <div class="info-linje"><b>Adresse</b><span>{site.adresse.gade}<br />{site.adresse.postnr} {site.adresse.by}</span></div>
            <div class="info-linje"><b>Telefon</b><span><a href={`tel:${site.telefonE164}`} style="color:var(--cobalt);text-decoration:underline">{site.telefon}</a></span></div>
            <div class="info-linje"><b>E-mail</b><span><a href={`mailto:${site.email}`} style="color:var(--cobalt);text-decoration:underline">{site.email}</a></span></div>
            {site.aabningstider.map((a) => (
              <div class="info-linje"><b>{a.dage}</b><span>{a.tid}</span></div>
            ))}
          </div>
          <a href={site.maps} class="btn btn-cobalt" style="margin-top:20px">Find vej på kort <span class="pil">→</span></a>
        </div>

        <div class="reveal">
          <h2 class="display-m" style="margin-bottom:8px">Send os en besked</h2>
          <p style="color:#3c3c46;margin-bottom:20px">
            Udfyld formularen, så vender vi tilbage hurtigst muligt.
          </p>
          <form action="/api/reserver" method="POST">
            <input type="hidden" name="type" value="kontakt" />
            <input type="hidden" name="objekt" value="Generel henvendelse" />
            <input type="checkbox" name="botcheck" style="display:none !important" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <div class="felt">
              <label for="k-navn">Navn</label>
              <input id="k-navn" name="navn" type="text" required autocomplete="name" placeholder="Dit navn" />
            </div>
            <div class="felt">
              <label for="k-tlf">Telefon</label>
              <input id="k-tlf" name="telefon" type="tel" required autocomplete="tel" placeholder="Så vi kan ringe tilbage" />
            </div>
            <div class="felt">
              <label for="k-email">E-mail</label>
              <input id="k-email" name="email" type="email" required autocomplete="email" placeholder="dig@eksempel.dk" />
            </div>
            <div class="felt">
              <label for="k-tid">Hvornår passer det dig?</label>
              <select id="k-tid" name="tid">
                {tidValg.map((t) => <option value={t.value}>{t.label}</option>)}
              </select>
            </div>
            <div class="felt">
              <label for="k-besked">Besked</label>
              <textarea id="k-besked" name="besked" rows="4" placeholder="Hvad kan vi hjælpe med?"></textarea>
            </div>
            <button type="submit" class="btn btn-cobalt">Send besked <span class="pil">→</span></button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
