---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tak for din reservation"
  description="Tak for din henvendelse til Cykelmov. Vi vender tilbage inden for én arbejdsdag."
  medModal={false}
>
  <div class="konfetti-lag" id="konfetti" aria-hidden="true"></div>
  <section class="tak-side">
    <div class="tak-kort reveal synlig" id="tak-kort">
      <span class="tak-cykel" aria-hidden="true">🚲</span>
      <div class="flueben">✓</div>
      <h1 id="tak-titel">Sådan! Vi holder den klar til dig</h1>
      <p id="tak-tekst">
        Tak. Vi holder den klar til afhentning i butikken på Nørrebrogade 74 og bekræfter din
        bestilling inden for én arbejdsdag. Du betaler først, når du henter.
      </p>
      <p style="color:var(--grå);font-size:.95rem">
        Har du travlt, er du altid velkommen til at ringe på
        <a href="tel:+4531327055" style="color:var(--cobalt);text-decoration:underline">31 32 70 55</a>.
      </p>
      <div class="knapper">
        <a href="/cykler/" class="btn btn-cobalt">Se flere cykler <span class="pil">→</span></a>
        <a href="/" class="btn btn-ghost">Til forsiden</a>
      </div>
    </div>
  </section>

  <script>
    const harTak = new URLSearchParams(location.search).has('tak');

    if (!harTak) {
      // Direkte besøg (uden ?tak=1): vis en mere generel invitation.
      const t = document.getElementById('tak-titel');
      const p = document.getElementById('tak-tekst');
      if (t) t.textContent = 'Reservér din cykel online';
      if (p)
        p.textContent =
          'Find din cykel, tryk Reservér, og udfyld dine oplysninger. Så står den klar med dit navn på, og du betaler først i butikken.';
    } else {
      // Dopamin: fejr den gennemførte bestilling.
      const kort = document.getElementById('tak-kort');
      kort?.classList.add('fejr');

      const reduceret = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const lag = document.getElementById('konfetti');
      if (lag && !reduceret) {
        const farver = ['#1D3EE3', '#FFD02F', '#E84F8A', '#22c55e', '#ffffff'];
        const antal = 90;
        for (let i = 0; i < antal; i++) {
          const s = document.createElement('span');
          s.className = 'konfetti-stykke';
          const stoerrelse = 7 + Math.random() * 8;
          s.style.left = Math.random() * 100 + 'vw';
          s.style.width = stoerrelse + 'px';
          s.style.height = stoerrelse * (0.5 + Math.random()) + 'px';
          s.style.background = farver[(Math.random() * farver.length) | 0];
          s.style.animationDelay = Math.random() * 0.5 + 's';
          s.style.animationDuration = 2.2 + Math.random() * 1.8 + 's';
          if (Math.random() > 0.5) s.style.borderRadius = '50%';
          s.style.setProperty('--drift', (Math.random() * 2 - 1) * 18 + 'vw');
          s.style.setProperty('--spin', (Math.random() * 900 + 360) * (Math.random() > 0.5 ? 1 : -1) + 'deg');
          lag.appendChild(s);
        }
        // Ryd op efter animationen.
        window.setTimeout(() => (lag.innerHTML = ''), 4600);
      }
    }
  </script>
</Layout>
